## 18. INTRA-CLASS CODE ORDERING

Always follow this order inside every class:

### Controller:
```dart
class DocumentDetailController extends GetxController {
  // 1. Services / dependencies
  final DocumentAnalysisService _analysisService = Get.find();
  final MarketDataService _marketService = Get.find();

  // 2. Reactive state (.obs)
  final analysis      = Rxn<DocumentAnalysisModel>();
  final marketInsight = Rxn<MarketInsightModel>();
  final isLoading     = false.obs;
  final hasError      = false.obs;
  final errorMessage  = ''.obs;

  // 3. Non-reactive variables
  late final String documentId;

  // 4. Controllers & keys
  final scrollController = ScrollController();

  // 5. Getters
  bool get hasData => analysis.value != null;

  // 6. Lifecycle (onInit ‚Üí onReady ‚Üí onClose)
  @override
  void onInit() {
    super.onInit();
    documentId = (Get.arguments as DocumentModel).id;
    _loadAll();
  }

  @override
  void onClose() {
    scrollController.dispose();
    super.onClose();
  }

  // 7. Public methods
  Future<void> refresh() async => _loadAll();

  // 8. Private methods
  Future<void> _loadAll() async { ... }
  void _handleError(Object e) { ... }
}
```

